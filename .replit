modules = ["bash", "web", "nodejs-22"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["flyctl"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash start-dev.sh"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3002

[deployment]
deploymentTarget = "autoscale"
run = ["node", "serve-prod.js"]
build = ["bash", "build-prod.sh"]
publicDir = "packages/desktop-client/build"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
